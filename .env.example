# Copy this file to .env and fill in your values

# OpenAI API Key (required)
OPENAI_API_KEY=sk-...

# GitHub Personal Access Token (optional, but recommended for higher rate limits & private repos)
# Create one at: https://github.com/settings/tokens
# Required scopes: repo (read), public_repo
# If not set, public repos can still be accessed with lower rate limits (60 req/hr vs 5000)
GITHUB_TOKEN=ghp_...

# LLM model to use (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# Output directory for generated reports
OUTPUT_DIR=./output
